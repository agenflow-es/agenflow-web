# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# stray local brand-asset copy (not part of the repo)
/design/agenflow-brand/favicon/icon-maskable-512_biiger.png

# internal docs — local only, never pushed (identity, strategy, previews)
/design/agenflow-brand/IDENTIDAD.md
/design/preview/
/design/shadcn-componentes-seleccion.md
/marketing/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but track the secret-free template so required vars are documented
!.env.example

# vercel
.vercel

# claude code scratch output (screenshot-verifier, etc.)
/.claude/tmp/

# typescript
*.tsbuildinfo
next-env.d.ts
