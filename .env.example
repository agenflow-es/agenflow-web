# Public site URL — used for SEO (sitemap, canonical, hreflang)
NEXT_PUBLIC_SITE_URL=https://agenflow.es

# Contact email shown on the site (footer + contact page)
NEXT_PUBLIC_CONTACT_EMAIL=info@agenflow.es

# Resend — contact form email delivery (https://resend.com)
RESEND_API_KEY=
# Verified sender on your Resend domain
CONTACT_FROM=web@agenflow.es
# Inbox that receives contact form submissions
CONTACT_EMAIL=info@agenflow.es
# Resend Audience that newsletter sign-ups (/recursos/newsletter) are added to.
# Gated: until this AND RESEND_API_KEY are set, the form returns an error
# instead of crashing. Find it in Resend → Audiences.
RESEND_AUDIENCE_ID=

# Anthropic API — powers the live "what does AI say about your business" check
# on /servicios/presencia-online (Claude + web search). Gated: until this is
# set the widget shows a friendly "coming soon" state instead of crashing.
ANTHROPIC_API_KEY=
