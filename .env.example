# Public site URL — used for SEO (sitemap, canonical, hreflang)
NEXT_PUBLIC_SITE_URL=https://agenflow.es

# Contact email shown on the site (footer + contact page)
NEXT_PUBLIC_CONTACT_EMAIL=info@agenflow.es

# Resend — contact form email delivery (https://resend.com)
RESEND_API_KEY=
# Verified sender on your Resend domain. Any local-part works (no mailbox needed);
# must be on a domain/subdomain VERIFIED in Resend. Hoy el dominio verificado es
# hola.agenflow.es (notifications.agenflow.es NO está verificado -> Resend rechaza el envío).
CONTACT_FROM=web@hola.agenflow.es
# Inbox that receives contact form submissions
CONTACT_EMAIL=info@agenflow.es
# Resend Audience that newsletter sign-ups (/recursos/newsletter) are added to.
# Gated: until this AND RESEND_API_KEY are set, the form returns an error
# instead of crashing. Find it in Resend → Audiences.
RESEND_AUDIENCE_ID=

# Anthropic API — powers the live "what does AI say about your business" check
# on /servicios/presencia-online (Claude + web search). Gated: until this is
# set the widget shows a friendly "coming soon" state instead of crashing.
ANTHROPIC_API_KEY=

# Origen del servidor de páginas-para-leads (propuestas). Si está vacío,
# /propuesta-web/:slug no se reescribe (la web queda como está). En Vercel
# se define por entorno (Preview/Prod) apuntando a agenflow-lead-pages.
LEAD_PAGES_ORIGIN=

# Captura inbound: URL pública de la Edge Function (Supabase) que recibe cada envío
# del formulario de contacto, ADEMÁS de Resend. Gated: si está vacía, el form solo
# dispara Resend. NEXT_PUBLIC_ porque el POST corre en el navegador (la función es
# pública e Origin-gated; no lleva credenciales). Va SOLO en Production: en Preview/
# localhost la función responde 403 por CORS (correcto — no deben escribir en el inbound).
NEXT_PUBLIC_INBOUND_CAPTURE_URL=
